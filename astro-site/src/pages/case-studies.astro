---
import BaseLayout from '../layouts/BaseLayout.astro';

const caseStudies = [
  {
    id: 'retail-ai',
    client: 'Regional Retail Chain',
    industry: 'Retail',
    challenge: 'Manual inventory management causing stockouts and overstock across 15 locations',
    solution: 'Implemented cloud-based inventory forecasting using machine learning and real-time BI dashboards',
    results: [
      { metric: '35%', label: 'Reduction in stockouts' },
      { metric: '$180K', label: 'Annual savings' },
      { metric: '4 weeks', label: 'Implementation time' }
    ],
    technologies: ['Machine Learning', 'Data Warehouse', 'BI Dashboards', 'Serverless Functions'],
    quote: 'NEWFTEC helped us compete with big-box retailers using AI we thought was out of reach for a company our size.',
    image: '/assets/images/case-retail.jpg'
  },
  // {
  //   id: 'manufacturing-iot',
  //   client: 'Precision Manufacturing Co.',
  //   industry: 'Manufacturing',
  //   challenge: 'No visibility into equipment health leading to unexpected downtime and maintenance costs',
  //   solution: 'Deployed IoT sensors connected to a cloud platform with predictive maintenance models',
  //   results: [
  //     { metric: '60%', label: 'Reduction in unplanned downtime' },
  //     { metric: '25%', label: 'Maintenance cost savings' },
  //     { metric: '99.2%', label: 'Equipment uptime achieved' }
  //   ],
  //   technologies: ['IoT Platform', 'Stream Analytics', 'Digital Twins', 'BI Dashboards'],
  //   quote: 'We went from reactive to predictive maintenance in just two months. The ROI was immediate.',
  //   image: '/assets/images/case-manufacturing.jpg'
  // },
  {
    id: 'warrior-rendezvous',
    client: 'Agro-Tourism Resort and Farm Stay',
    industry: 'Nonprofit / Agriculture',
    challenge: 'Needed a modern, mission-driven web presence to engage supporters, streamline donations, and amplify impact.',
    solution: 'Delivered a state-of-the-art website using Astro, blending custom branding, dynamic content, e-commerce, and interactive tools for a seamless, accessible, and high-performance experience.',
    results: [
      { metric: '2 weeks', label: 'Implementation time' },
      { metric: '↑ Bookings', label: 'Increased Engagement & Booking' },
      { metric: '↑ Sales', label: 'Increased website sales' }
    ],
    technologies: [
      'Astro Framework',
      'Azure Web Apps',
      'Dynamic Blog & Stories',
      'PayPal & Donorbox',
      'Ecwid Shop',
      'Azure Foundry',
      'Application Insights',
      'Mobile Optimization'
    ],
    quote: 'Our new website is more than a digital brochure - it is a powerful platform for impact. We are reaching more people, inspiring more action, and focusing on what matters most. The partnership and technical excellence made all the difference.',
    image: '/assets/images/case-legal.jpg'
  }
];
---

<BaseLayout 
  title="Case Studies | NEWFTEC"
  description="Real results from real businesses. See how NEWFTEC's cloud and AI solutions have transformed operations across industries."
  currentPage="/case-studies"
>
  <section class="case-studies-hero">
    <div class="container">
      <h1>Client Success Stories</h1>
      <p>Real results from businesses like yours. See how we've helped companies transform with cloud and AI.</p>
    </div>
  </section>

  <section class="case-studies-list">
    <div class="container">
      {caseStudies.map((study, index) => (
        <article class="case-study" id={study.id}>
          <div class="case-study-header">
            <span class="industry-badge">{study.industry}</span>
            <h2>{study.client}</h2>
          </div>
          
          <div class="case-study-content">
            <div class="challenge-solution">
              <div class="block">
                <h3>The Challenge</h3>
                <p>{study.challenge}</p>
              </div>
              <div class="block">
                <h3>Our Solution</h3>
                <p>{study.solution}</p>
              </div>
            </div>

            <div class="results">
              <h3>Results</h3>
              <div class="metrics">
                {study.results.map(result => (
                  <div class="metric">
                    <span class="metric-value">{result.metric}</span>
                    <span class="metric-label">{result.label}</span>
                  </div>
                ))}
              </div>
            </div>

            <blockquote class="quote">
              "{study.quote}"
            </blockquote>

            <div class="tech-used">
              <h4>Technologies Used</h4>
              <div class="tech-tags">
                {study.technologies.map(tech => (
                  <span class="tech-tag">{tech}</span>
                ))}
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Ready to Be Our Next Success Story?</h2>
      <p>Let's discuss how we can achieve similar results for your business.</p>
      <a href="/contact" class="cta-button">Start the Conversation</a>
    </div>
  </section>
</BaseLayout>

<style>

  .case-studies-hero {
    background: var(--accent-gradient);
    color: var(--text-inverse);
    padding: 80px 0;
    text-align: center;
  }

  .case-studies-hero h1 {
    font-size: 48px;
    font-weight: 700;
    margin-bottom: 20px;
  }

  .case-studies-hero p {
    font-size: 20px;
    color: var(--accent-light);
    max-width: 600px;
    margin: 0 auto;
  }

  .case-studies-list {
    padding: 60px 0;
  }

  .case-study {
    background: var(--bg-card);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 40px;
    box-shadow: var(--shadow-lg);
  }

  .case-study-header {
    background: var(--bg-tertiary);
    padding: 30px 40px;
    border-bottom: 1px solid var(--border-color);
  }

  .industry-badge {
    display: inline-block;
    background: var(--accent-primary);
    color: var(--text-inverse);
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 10px;
  }

  .case-study-header h2 {
    font-size: 28px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .case-study-content {
    padding: 40px;
  }

  .challenge-solution {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    margin-bottom: 40px;
  }

  .block h3 {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 10px;
  }

  .block p {
    font-size: 17px;
    color: var(--text-primary);
    line-height: 1.6;
  }

  .results {
    background: var(--accent-bg);
    border-radius: 12px;
    padding: 30px;
    margin-bottom: 30px;
  }

  .results h3 {
    font-size: 14px;
    font-weight: 600;
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 20px;
  }

  .metrics {
    display: flex;
    gap: 40px;
    flex-wrap: wrap;
  }

  .metric {
    text-align: center;
  }

  .metric-value {
    display: block;
    font-size: 36px;
    font-weight: 700;
    color: var(--accent-primary);
    line-height: 1;
  }

  .metric-label {
    display: block;
    font-size: 14px;
    color: var(--accent-hover);
    margin-top: 8px;
  }

  .quote {
    font-size: 20px;
    font-style: italic;
    color: var(--text-secondary);
    border-left: 4px solid var(--accent-primary);
    padding-left: 25px;
    margin: 30px 0;
    line-height: 1.6;
  }

  .tech-used h4 {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 15px;
  }

  .tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tech-tag {
    background: var(--accent-gradient-soft);
    color: var(--accent-primary);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 500;
  }

  .cta-section {
    background: var(--bg-dark);
    color: var(--text-inverse);
    padding: 80px 0;
    text-align: center;
  }

  .cta-section h2 {
    font-size: 36px;
    font-weight: 700;
    margin-bottom: 15px;
  }

  .cta-section p {
    font-size: 18px;
    color: var(--text-secondary);
    margin-bottom: 30px;
  }

  .cta-button {
    display: inline-block;
    background: var(--accent-tertiary);
    color: var(--text-inverse);
    padding: 14px 32px;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .cta-button:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .case-studies-hero h1 {
      font-size: 32px;
    }

    .case-study-header, .case-study-content {
      padding: 25px;
    }

    .challenge-solution {
      grid-template-columns: 1fr;
      gap: 25px;
    }

    .metrics {
      justify-content: center;
    }
  }
</style>
